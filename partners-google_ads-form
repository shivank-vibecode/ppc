
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Deriv Partners – Google Ads Campaign Questionnaire</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  :root {
    --coral:     #FF444F;
    --coral-dark:#E0333D;
    --coral-light:#FFF0F1;
    --slate:     #181C25;
    --slate-mid: #3E4455;
    --slate-light:#6B7280;
    --border:    #E5E7EB;
    --bg:        #F7F8FA;
    --white:     #FFFFFF;
    --radius:    8px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    color: var(--slate);
    min-height: 100vh;
    padding-bottom: 60px;
  }

  /* ── Top bar ── */
  .top-bar {
    background: var(--slate);
    height: 4px;
    width: 100%;
  }

  /* ── Page layout ── */
  .page {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 16px;
  }

  /* ── Header card ── */
  .header-card {
    background: var(--slate);
    border-radius: 0 0 var(--radius) var(--radius);
    padding: 36px 40px 32px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }

  .header-card::before {
    content: '';
    position: absolute;
    top: -40px; right: -40px;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(255,68,79,0.12);
    pointer-events: none;
  }

  .header-card::after {
    content: '';
    position: absolute;
    bottom: -60px; left: 60px;
    width: 160px; height: 160px;
    border-radius: 50%;
    background: rgba(255,68,79,0.07);
    pointer-events: none;
  }

  .logo {
    height: 28px;
    margin-bottom: 24px;
    display: block;
  }

  .form-title {
    font-size: 24px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 10px;
    line-height: 1.2;
  }

  .form-title span {
    color: var(--coral);
  }

  .form-desc {
    font-size: 13.5px;
    color: rgba(255,255,255,0.65);
    line-height: 1.65;
    max-width: 520px;
  }

  .required-note {
    margin-top: 16px;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
  }

  .required-note span { color: var(--coral); }

  /* ── Section label ── */
  .section-label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 24px 0 8px;
  }

  .section-label-text {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--coral);
  }

  .section-label-line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ── Question card ── */
  .card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 24px 28px;
    margin-bottom: 10px;
    border: 1.5px solid transparent;
    transition: border-color 0.18s, box-shadow 0.18s;
    box-shadow: 0 1px 3px rgba(24,28,37,0.06);
  }

  .card:focus-within {
    border-color: var(--coral);
    box-shadow: 0 0 0 3px rgba(255,68,79,0.08);
  }

  /* ── Question label ── */
  .q-label {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--slate);
    margin-bottom: 4px;
    line-height: 1.45;
  }

  .q-label .star { color: var(--coral); margin-left: 2px; }

  .q-hint {
    font-size: 12.5px;
    color: var(--slate-light);
    margin-bottom: 14px;
    line-height: 1.5;
  }

  /* ── Text input ── */
  .text-field {
    width: 100%;
    border: none;
    border-bottom: 1.5px solid var(--border);
    outline: none;
    font-size: 14px;
    font-family: 'Inter', sans-serif;
    color: var(--slate);
    padding: 8px 0;
    background: transparent;
    transition: border-color 0.18s;
  }

  .text-field:focus { border-bottom-color: var(--coral); }
  .text-field::placeholder { color: #BDC1CC; }

  /* ── Options ── */
  .opts { display: flex; flex-direction: column; gap: 2px; margin-top: 8px; }

  .opt {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 9px 12px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.12s;
  }

  .opt:hover { background: var(--coral-light); }

  .opt input[type="radio"],
  .opt input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 17px;
    height: 17px;
    border: 2px solid var(--border);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 1px;
    cursor: pointer;
    position: relative;
    transition: border-color 0.15s, background 0.15s;
  }

  .opt input[type="checkbox"] { border-radius: 4px; }

  .opt input[type="radio"]:checked,
  .opt input[type="checkbox"]:checked {
    background: var(--coral);
    border-color: var(--coral);
  }

  .opt input[type="radio"]:checked::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 6px; height: 6px;
    border-radius: 50%;
    background: white;
  }

  .opt input[type="checkbox"]:checked::after {
    content: '';
    position: absolute;
    top: 2px; left: 5px;
    width: 4px; height: 7px;
    border: 2px solid white;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  .opt label {
    font-size: 13.5px;
    color: var(--slate-mid);
    cursor: pointer;
    line-height: 1.45;
    padding-top: 1px;
  }

  /* ── Conditional block ── */
  .conditional {
    display: none;
    background: #FFF8F8;
    border-left: 3px solid var(--coral);
    border-radius: 0 6px 6px 0;
    padding: 16px 20px;
    margin-top: 14px;
    flex-direction: column;
    gap: 20px;
  }

  .conditional.show { display: flex; }
  .conditional .q-label { font-size: 13.5px; color: var(--slate-mid); }

  /* ── Other input ── */
  .other-wrap { display: none; padding-left: 29px; margin-top: 4px; }
  .other-wrap.show { display: block; }
  .other-field {
    width: 100%;
    border: none;
    border-bottom: 1px solid var(--border);
    outline: none;
    font-size: 13px;
    font-family: 'Inter', sans-serif;
    color: var(--slate);
    padding: 4px 0;
    background: transparent;
  }
  .other-field:focus { border-bottom-color: var(--coral); }
  .other-field::placeholder { color: #BDC1CC; }

  /* ── Submit area ── */
  .submit-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 24px 28px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-shadow: 0 1px 3px rgba(24,28,37,0.06);
  }

  .btn-submit {
    background: var(--coral);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 12px 32px;
    font-size: 14px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    letter-spacing: 0.2px;
    transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
  }

  .btn-submit:hover {
    background: var(--coral-dark);
    box-shadow: 0 4px 12px rgba(255,68,79,0.35);
    transform: translateY(-1px);
  }

  .btn-submit:active { transform: translateY(0); }

  .btn-clear {
    font-size: 13px;
    color: var(--slate-light);
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: color 0.15s;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .btn-clear:hover { color: var(--coral); }

  /* ── Footer ── */
  .footer {
    text-align: center;
    font-size: 12px;
    color: var(--slate-light);
    margin-top: 20px;
    padding-bottom: 20px;
  }
</style>
</head>
<body>

<div class="top-bar"></div>

<div class="page">

  <!-- Header -->
  <div class="header-card">
    <img class="logo" src="data:image/png;base64," alt="Deriv Partners">
    <div class="form-title">Google Ads <span>Campaign</span> Questionnaire</div>
    <div class="form-desc">Help us understand your goals so we can set you up for success with paid campaigns on Google Ads. The more detail you share, the better we can support you.</div>
    <div class="required-note"><span>*</span> Required field</div>
  </div>

  <!-- ═══ YOUR DETAILS ═══ -->
  <div class="section-label">
    <span class="section-label-text">Your Details</span>
    <div class="section-label-line"></div>
  </div>

  <div class="card">
    <div class="q-label">Full Name <span class="star">*</span></div>
    <input class="text-field" type="text" placeholder="Your full name" id="fullName">
  </div>

  <div class="card">
    <div class="q-label">Email Address / WhatsApp Number <span class="star">*</span></div>
    <div class="q-hint">Provide whichever you prefer to be contacted on</div>
    <input class="text-field" type="text" placeholder="e.g. name@email.com or +60 12-345 6789" id="emailWhatsapp">
  </div>

  <div class="card">
    <div class="q-label">Partner ID <span class="star">*</span></div>
    <div class="q-hint">Found in your Deriv affiliate dashboard</div>
    <input class="text-field" type="text" placeholder="e.g. PA12345" id="partnerId">
  </div>

  <!-- ═══ EXPERIENCE ═══ -->
  <div class="section-label">
    <span class="section-label-text">Experience &amp; Background</span>
    <div class="section-label-line"></div>
  </div>

  <div class="card">
    <div class="q-label">Do you currently run, or have you previously run, paid advertising campaigns? <span class="star">*</span></div>
    <div class="opts">
      <div class="opt">
        <input type="radio" name="q_exp" id="e1" onchange="toggleExp()">
        <label for="e1">Yes, I'm actively running campaigns</label>
      </div>
      <div class="opt">
        <input type="radio" name="q_exp" id="e2" onchange="toggleExp()">
        <label for="e2">Yes, but not currently</label>
      </div>
      <div class="opt">
        <input type="radio" name="q_exp" id="e3" onchange="toggleExp()">
        <label for="e3">No, this would be my first time</label>
      </div>
    </div>

    <div class="conditional" id="expDetails">
      <div>
        <div class="q-label">Which advertising platforms have you used? <span style="font-weight:400;color:var(--slate-light)">(Select all that apply)</span></div>
        <div class="opts" style="margin-top:10px">
          <div class="opt"><input type="checkbox" id="pl1"><label for="pl1">Google Ads</label></div>
          <div class="opt"><input type="checkbox" id="pl2"><label for="pl2">Meta (Facebook &amp; Instagram)</label></div>
          <div class="opt"><input type="checkbox" id="pl3"><label for="pl3">TikTok Ads</label></div>
          <div class="opt"><input type="checkbox" id="pl4"><label for="pl4">Native Ads (Taboola, Outbrain)</label></div>
          <div class="opt">
            <input type="checkbox" id="pl5" onchange="toggleOther('pl5','otherPlatform')">
            <label for="pl5">Other</label>
          </div>
          <div class="other-wrap" id="otherPlatform">
            <input class="other-field" type="text" placeholder="Please specify…" id="otherPlatformText">
          </div>
        </div>
      </div>
      <div>
        <div class="q-label">What is your current or planned daily budget for Google Ads?</div>
        <div class="opts" style="margin-top:10px">
          <div class="opt"><input type="radio" name="q_budget" id="bu1"><label for="bu1">Under 0 / day</label></div>
          <div class="opt"><input type="radio" name="q_budget" id="bu2"><label for="bu2">0 – 00 / day</label></div>
          <div class="opt"><input type="radio" name="q_budget" id="bu3"><label for="bu3">00 – 00 / day</label></div>
          <div class="opt"><input type="radio" name="q_budget" id="bu4"><label for="bu4">00+ / day</label></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ CAMPAIGN SETUP ═══ -->
  <div class="section-label">
    <span class="section-label-text">Campaign Setup</span>
    <div class="section-label-line"></div>
  </div>

  <div class="card">
    <div class="q-label">Which Google Ads campaign type(s) are you interested in running? <span class="star">*</span></div>
    <div class="q-hint">Select all that apply</div>
    <div class="opts">
      <div class="opt"><input type="checkbox" id="ct1"><label for="ct1">Search</label></div>
      <div class="opt"><input type="checkbox" id="ct2"><label for="ct2">Display</label></div>
      <div class="opt"><input type="checkbox" id="ct3"><label for="ct3">YouTube</label></div>
      <div class="opt"><input type="checkbox" id="ct4"><label for="ct4">Performance Max</label></div>
      <div class="opt"><input type="checkbox" id="ct5"><label for="ct5">App Campaigns</label></div>
      <div class="opt"><input type="checkbox" id="ct6"><label for="ct6">Not sure — I'd like guidance</label></div>
    </div>
  </div>

  <div class="card">
    <div class="q-label">Which stage of the funnel will your campaigns primarily target? <span class="star">*</span></div>
    <div class="opts">
      <div class="opt"><input type="radio" name="q_funnel" id="fn1"><label for="fn1">Awareness — new audiences unfamiliar with the brand</label></div>
      <div class="opt"><input type="radio" name="q_funnel" id="fn2"><label for="fn2">Consideration — users actively researching trading / financial platforms</label></div>
      <div class="opt"><input type="radio" name="q_funnel" id="fn3"><label for="fn3">Conversion — users ready to sign up or make a deposit</label></div>
      <div class="opt"><input type="radio" name="q_funnel" id="fn4"><label for="fn4">Retention / Re-engagement — existing users</label></div>
    </div>
  </div>

  <div class="card">
    <div class="q-label">Which countries are you planning to target? <span class="star">*</span></div>
    <input class="text-field" type="text" placeholder="e.g. Malaysia, Nigeria, Brazil…" id="targetCountries">
  </div>

  <div class="card">
    <div class="q-label">Which language(s) will your ads be in? <span class="star">*</span></div>
    <input class="text-field" type="text" placeholder="e.g. English, Arabic, Portuguese…" id="adLanguages">
  </div>

  <!-- ═══ TECHNICAL READINESS ═══ -->
  <div class="section-label">
    <span class="section-label-text">Technical Readiness</span>
    <div class="section-label-line"></div>
  </div>

  <div class="card">
    <div class="q-label">Do you have a landing page or website ready to drive traffic to? <span class="star">*</span></div>
    <div class="opts">
      <div class="opt"><input type="radio" name="q_lp" id="lp1"><label for="lp1">Yes, it's live</label></div>
      <div class="opt"><input type="radio" name="q_lp" id="lp2"><label for="lp2">Yes, but it needs updates</label></div>
      <div class="opt"><input type="radio" name="q_lp" id="lp3"><label for="lp3">No, I need help setting one up</label></div>
    </div>
  </div>

  <!-- ═══ GOALS & SUPPORT ═══ -->
  <div class="section-label">
    <span class="section-label-text">Goals &amp; Support</span>
    <div class="section-label-line"></div>
  </div>

  <div class="card">
    <div class="q-label">What kind of support are you looking for from the Deriv team? <span class="star">*</span></div>
    <div class="q-hint">Select all that apply</div>
    <div class="opts">
      <div class="opt"><input type="checkbox" id="sp1"><label for="sp1">Keyword strategy</label></div>
      <div class="opt"><input type="checkbox" id="sp2"><label for="sp2">Ad copy review</label></div>
      <div class="opt"><input type="checkbox" id="sp3"><label for="sp3">Creative assets (banners, videos)</label></div>
      <div class="opt"><input type="checkbox" id="sp4"><label for="sp4">Landing page feedback</label></div>
      <div class="opt"><input type="checkbox" id="sp5"><label for="sp5">Reporting &amp; optimisation</label></div>
      <div class="opt"><input type="checkbox" id="sp6"><label for="sp6">All of the above</label></div>
    </div>
  </div>

  <!-- Submit -->
  <div class="submit-card">
    <button class="btn-submit" type="button" onclick="submitForm()">Submit</button>
    <button class="btn-clear" type="button" onclick="clearForm()">Clear form</button>
  </div>

  <div class="footer">© Deriv Partners · Never submit passwords through this form</div>

</div>

<script>
  // ══════════════════════════════════════════════════════
  // IMPORTANT: Replace the URL below with your Web App URL
  // ══════════════════════════════════════════════════════
  const GOOGLE_SHEET_URL = 'https://script.google.com/a/macros/regentmarkets.com/s/AKfycbxmYchSsAi0PZdFupuHSsBKX8G-JyNMVSEOCQer-BWus7EFYklMHTJTLFysFTFPHQru/exec';

  function toggleExp() {
    const val = document.querySelector('input[name="q_exp"]:checked')?.id;
    document.getElementById('expDetails').classList.toggle('show', val === 'e1' || val === 'e2');
  }

  function toggleOther(cbId, wrapId) {
    const checked = document.getElementById(cbId).checked;
    document.getElementById(wrapId).classList.toggle('show', checked);
  }

  function clearForm() {
    document.querySelectorAll('input[type="radio"],input[type="checkbox"]').forEach(el => el.checked = false);
    document.querySelectorAll('input[type="text"]').forEach(el => el.value = '');
    document.getElementById('expDetails').classList.remove('show');
    document.getElementById('otherPlatform').classList.remove('show');
  }

  // Helper: get label text for a checked radio button
  function getRadioLabel(name) {
    const checked = document.querySelector('input[name="' + name + '"]:checked');
    if (!checked) return '';
    const label = document.querySelector('label[for="' + checked.id + '"]');
    return label ? label.textContent.trim() : '';
  }

  // Helper: get label texts for all checked checkboxes by ID prefix
  function getCheckedLabels(prefix, count) {
    const results = [];
    for (let i = 1; i <= count; i++) {
      const cb = document.getElementById(prefix + i);
      if (cb && cb.checked) {
        const label = document.querySelector('label[for="' + prefix + i + '"]');
        if (label) results.push(label.textContent.trim());
      }
    }
    return results;
  }

  function validateForm() {
    const fullName = document.getElementById('fullName').value.trim();
    const email = document.getElementById('emailWhatsapp').value.trim();
    const partnerId = document.getElementById('partnerId').value.trim();
    const adExp = getRadioLabel('q_exp');
    const campaignTypes = getCheckedLabels('ct', 6);
    const funnelStage = getRadioLabel('q_funnel');
    const countries = document.getElementById('targetCountries').value.trim();
    const languages = document.getElementById('adLanguages').value.trim();
    const landingPage = getRadioLabel('q_lp');
    const support = getCheckedLabels('sp', 6);

    const missing = [];
    if (!fullName) missing.push('Full Name');
    if (!email) missing.push('Email Address / WhatsApp Number');
    if (!partnerId) missing.push('Partner ID');
    if (!adExp) missing.push('Advertising Experience');
    if (campaignTypes.length === 0) missing.push('Campaign Types');
    if (!funnelStage) missing.push('Funnel Stage');
    if (!countries) missing.push('Target Countries');
    if (!languages) missing.push('Ad Languages');
    if (!landingPage) missing.push('Landing Page');
    if (support.length === 0) missing.push('Support Needed');

    return missing;
  }

  async function submitForm() {
    // Validate required fields
    const missing = validateForm();
    if (missing.length > 0) {
      alert('Please complete the following required fields:\n\n• ' + missing.join('\n• '));
      return;
    }

    // Collect all form data
    const data = {
      fullName: document.getElementById('fullName').value.trim(),
      emailWhatsapp: document.getElementById('emailWhatsapp').value.trim(),
      partnerId: document.getElementById('partnerId').value.trim(),
      adExperience: getRadioLabel('q_exp'),
      platforms: getCheckedLabels('pl', 5),
      otherPlatform: document.getElementById('otherPlatformText').value.trim(),
      dailyBudget: getRadioLabel('q_budget'),
      campaignTypes: getCheckedLabels('ct', 6),
      funnelStage: getRadioLabel('q_funnel'),
      targetCountries: document.getElementById('targetCountries').value.trim(),
      adLanguages: document.getElementById('adLanguages').value.trim(),
      landingPage: getRadioLabel('q_lp'),
      supportNeeded: getCheckedLabels('sp', 6)
    };

    // Disable submit button while sending
    const btn = document.querySelector('.btn-submit');
    const originalText = btn.textContent;
    btn.textContent = 'Submitting…';
    btn.disabled = true;
    btn.style.opacity = '0.6';

    try {
      if (GOOGLE_SHEET_URL === 'PASTE_YOUR_WEB_APP_URL_HERE') {
        alert('⚠️ Setup needed: Please replace PASTE_YOUR_WEB_APP_URL_HERE in the HTML file with your Google Sheets Web App URL.');
        return;
      }

      const response = await fetch(GOOGLE_SHEET_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      // Show success message
      document.querySelector('.page').innerHTML = `
        <div class="header-card" style="text-align:center; margin-top:40px;">
          <div style="font-size:48px; margin-bottom:16px;">✓</div>
          <div class="form-title">Thank you!</div>
          <div class="form-desc" style="margin:12px auto 0; max-width:400px;">
            Your responses have been recorded. The Deriv team will review your answers and get back to you shortly.
          </div>
        </div>
        <div class="submit-card" style="text-align:center; margin-top:20px;">
          <button class="btn-submit" onclick="location.reload()" style="background:var(--slate-mid);">Submit another response</button>
        </div>
      `;

    } catch (error) {
      alert('Something went wrong. Please try again or contact support.\n\nError: ' + error.message);
    } finally {
      btn.textContent = originalText;
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  }
</script>
</body>
</html>
